{
  "manifest_version": 3,
  "name": "DC 悬浮记事本",
  "version": "1.0.0",
  "description": "悬浮在 DC 左上角的轻量记事本，支持文字/截图/语音录入，自动归类整理",
  "permissions": [
    "storage",
    "clipboardRead",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://im.xiaojukeji.com/*",
    "https://*.xiaojukeji.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://im.xiaojukeji.com/*",
        "https://*.xiaojukeji.com/*"
      ],
      "js": [
        "content_scripts/notepad.js"
      ],
      "css": [
        "content_scripts/notepad.css"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "commands": {
    "toggle-notepad": {
      "suggested_key": {
        "default": "Alt+N"
      },
      "description": "切换记事本显示/隐藏"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}